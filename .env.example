# ============================================
# Drew Billing - Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Stripe (Test keys for development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Drew Billing Cloud (SaaS) Price IDs
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=price_...

# Drew Billing SDK License Price IDs
# Run: npx tsx scripts/create-stripe-sdk-products.ts
NEXT_PUBLIC_STRIPE_PRICE_SDK_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_SDK_TEAM=price_...
NEXT_PUBLIC_STRIPE_PRICE_SDK_ENTERPRISE=price_...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=billing@monetize-two.vercel.app

# Authentication (Better Auth)
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Error Tracking (Sentry)
# SENTRY_DSN=https://...
