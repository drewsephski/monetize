# ============================================
# Drew Billing - Production Environment
# Copy this file to .env.production.local or set in Vercel
# ============================================

# Database (Neon/Supabase)
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/database_name?sslmode=require

# Stripe LIVE Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Drew Billing Cloud (SaaS) Price IDs - LIVE
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_live_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=price_live_...

# Drew Billing SDK License Price IDs - LIVE
NEXT_PUBLIC_STRIPE_PRICE_SDK_PRO=price_live_...
NEXT_PUBLIC_STRIPE_PRICE_SDK_TEAM=price_live_...
NEXT_PUBLIC_STRIPE_PRICE_SDK_ENTERPRISE=price_live_...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=billing@monetize-two.vercel.app

# Authentication (Better Auth)
BETTER_AUTH_SECRET=<generate-32-char-random-string-here>
NEXT_PUBLIC_APP_URL=https://monetize-two.vercel.app

# Error Tracking (Sentry) - Optional but recommended
# Get from: https://sentry.io/settings/projects/
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org-name
# SENTRY_PROJECT=monetize

# Optional: Analytics (PostHog)
# POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_KEY=phc_...

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# [ ] Database migrated (bun run db:migrate)
# [ ] Stripe webhook endpoint configured in dashboard
# [ ] Email domain verified in Resend
# [ ] Environment variables set in Vercel
# [ ] Sentry DSN configured (optional)
# [ ] Test purchase flow end-to-end
# [ ] Verify license email delivery
# [ ] Test license key validation
# [ ] Test usage limit enforcement
