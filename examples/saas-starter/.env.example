# Billing configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs for your products (create in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_STARTER="price_..."
NEXT_PUBLIC_STRIPE_PRICE_GROWTH="price_..."
NEXT_PUBLIC_STRIPE_PRICE_SCALE="price_..."

# Local sandbox - set to "true" to test without real Stripe charges
# When sandbox is enabled, checkout redirects to dashboard immediately
BILLING_SANDBOX_MODE="true"
NEXT_PUBLIC_BILLING_SANDBOX_MODE="true"
