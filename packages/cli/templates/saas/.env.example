# Billing configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs - These are auto-populated when you run `npx drew-billing-cli init`
# Or manually create products in Stripe Dashboard and paste the price IDs here
NEXT_PUBLIC_STRIPE_PRICE_STARTER="price_..."
NEXT_PUBLIC_STRIPE_PRICE_PRO="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE="price_..."

# Database URL (required for subscription storage)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Local sandbox - set to "true" to test without real Stripe charges
# When sandbox is enabled, checkout redirects to dashboard immediately without payment
BILLING_SANDBOX_MODE="true"
NEXT_PUBLIC_BILLING_SANDBOX_MODE="true"
